  "animationTransition": {
    "feedback": {
      "$value": {
        "properties": [
          "color",
          "background-color",
          "border-color"
        ],
        "duration": "{animationDuration.swift}",
        "timingFunction": "{animationEasing.standard}"
      },
      "$type": "transition",
      "$description": "Hover and focus feedback on buttons, links, and menu items"
    },
    "reveal": {
      "$value": {
        "properties": [
          "opacity",
          "transform"
        ],
        "duration": "{animationDuration.deliberate}",
        "timingFunction": "{animationEasing.entrance}"
      },
      "$type": "transition",
      "$description": "Menus, cards, and overlays entering view"
    },
    "conceal": {
      "$value": {
        "properties": [
          "opacity",
          "transform"
        ],
        "duration": "{animationDuration.moderate}",
        "timingFunction": "{animationEasing.exit}"
      },
      "$type": "transition",
      "$description": "Dismissed overlays and transient UI leaving view"
    },
    "progress": {
      "$value": {
        "properties": [
          "width",
          "opacity"
        ],
        "duration": "{animationDuration.moderate}",
        "timingFunction": "{animationEasing.linear}"
      },
      "$type": "transition",
      "$description": "Progress indicators and other continuous system updates"
    },
    "emphasis": {
      "$value": {
        "properties": [
          "transform",
          "opacity"
        ],
        "duration": "{animationDuration.swift}",
        "timingFunction": "{animationEasing.emphasized}"
      },
      "$type": "transition",
      "$description": "Compact emphasis shifts such as press states and dense affordances"
    }
  }
}
