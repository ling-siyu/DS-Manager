      "$extensions": {
        "com.securamark": {
          "lineHeight": "2.25rem"
        }
      }
    },
    "heroLogo": {
      "$value": "clamp(1.5rem,2.78vw,2.5rem)",
      "$type": "dimension",
      "$extensions": {
        "com.securamark": {
          "lineHeight": "1"
        }
      }
    },
    "displaySm": {
      "$value": "clamp(1.5rem,3vw,2.25rem)",
      "$type": "dimension",
      "$extensions": {
        "com.securamark": {
          "lineHeight": "1.15"
        }
      }
    },
    "displayLg": {
      "$value": "clamp(3rem,5.56vw,5rem)",
      "$type": "dimension",
      "$extensions": {
        "com.securamark": {
          "lineHeight": "1.05"
        }
      }
    },
    "landingHeroBody": {
      "$value": "clamp(0.875rem, 0.625rem + 0.5vw, 1.125rem)",
      "$type": "dimension",
      "$extensions": {
        "com.securamark": {
          "lineHeight": "clamp(1.25rem, 0.75rem + 1vw, 1.75rem)"
        }
      }
    },
    "landingFeatureEyebrow": {
      "$value": "clamp(0.875rem, 0.75rem + 0.25vw, 1rem)",
      "$type": "dimension",
      "$extensions": {
        "com.securamark": {
          "lineHeight": "clamp(1.25rem, 1rem + 0.5vw, 1.5rem)"
        }
      }
    },
    "landingFeatureTitle": {
      "$value": "clamp(2.25rem,7.5vw,3.25rem)",
      "$type": "dimension",
      "$extensions": {
        "com.securamark": {
          "lineHeight": "1.12"
        }
      }
    }
  },
  "animationDuration": {
    "instant": {
      "$value": "0ms",
      "$type": "duration"
    },
    "quick": {
      "$value": "100ms",
      "$type": "duration"
    },
    "swift": {
      "$value": "150ms",
      "$type": "duration"
    },
    "moderate": {
      "$value": "200ms",
      "$type": "duration"
    },
    "deliberate": {
      "$value": "300ms",
      "$type": "duration"
    }
  },
  "animationEasing": {
    "linear": {
      "$value": "linear",
      "$type": "cubicBezier"
    },
    "standard": {
      "$value": "cubic-bezier(0.2, 0, 0, 1)",
      "$type": "cubicBezier"
    },
    "entrance": {
      "$value": "cubic-bezier(0, 0, 0, 1)",
      "$type": "cubicBezier"
    },
    "exit": {
      "$value": "cubic-bezier(0.4, 0, 1, 1)",
      "$type": "cubicBezier"
    },
    "emphasized": {
      "$value": "cubic-bezier(0.2, 0, 0, 1)",
      "$type": "cubicBezier"
    }
  },
  "borderRadius": {
