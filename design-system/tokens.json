        "500": { "$value": "#6366f1", "$type": "color" },
        "600": { "$value": "#4f46e5", "$type": "color" },
        "700": { "$value": "#4338ca", "$type": "color" },
        "800": { "$value": "#3730a3", "$type": "color" },
        "900": { "$value": "#312e81", "$type": "color" },
        "950": { "$value": "#1e1b4b", "$type": "color" }
      },
      "red": {
        "50":  { "$value": "#fef2f2", "$type": "color" },
        "100": { "$value": "#fee2e2", "$type": "color" },
        "200": { "$value": "#fecaca", "$type": "color" },
        "300": { "$value": "#fca5a5", "$type": "color" },
        "400": { "$value": "#f87171", "$type": "color" },
        "500": { "$value": "#ef4444", "$type": "color" },
        "600": { "$value": "#dc2626", "$type": "color" },
        "700": { "$value": "#b91c1c", "$type": "color" },
        "800": { "$value": "#991b1b", "$type": "color" },
        "900": { "$value": "#7f1d1d", "$type": "color" },
        "950": { "$value": "#450a0a", "$type": "color" }
      },
      "yellow": {
        "50":  { "$value": "#fffbeb", "$type": "color" },
        "100": { "$value": "#fef3c7", "$type": "color" },
        "200": { "$value": "#fde68a", "$type": "color" },
        "300": { "$value": "#fcd34d", "$type": "color" },
        "400": { "$value": "#fbbf24", "$type": "color" },
        "500": { "$value": "#f59e0b", "$type": "color" },
        "600": { "$value": "#d97706", "$type": "color" },
        "700": { "$value": "#b45309", "$type": "color" },
        "800": { "$value": "#92400e", "$type": "color" },
        "900": { "$value": "#78350f", "$type": "color" },
        "950": { "$value": "#451a03", "$type": "color" }
      },
      "green": {
        "50":  { "$value": "#ecfdf5", "$type": "color" },
        "100": { "$value": "#d1fae5", "$type": "color" },
        "200": { "$value": "#a7f3d0", "$type": "color" },
        "300": { "$value": "#6ee7b7", "$type": "color" },
        "400": { "$value": "#34d399", "$type": "color" },
        "500": { "$value": "#10b981", "$type": "color" },
        "600": { "$value": "#059669", "$type": "color" },
        "700": { "$value": "#047857", "$type": "color" },
        "800": { "$value": "#065f46", "$type": "color" },
        "900": { "$value": "#064e3b", "$type": "color" },
        "950": { "$value": "#022c22", "$type": "color" }
      },
      "blue": {
        "50":  { "$value": "#eff6ff", "$type": "color" },
        "100": { "$value": "#dbeafe", "$type": "color" },
        "200": { "$value": "#bfdbfe", "$type": "color" },
        "300": { "$value": "#93c5fd", "$type": "color" },
        "400": { "$value": "#60a5fa", "$type": "color" },
        "500": { "$value": "#3b82f6", "$type": "color" },
        "600": { "$value": "#2563eb", "$type": "color" },
        "700": { "$value": "#1d4ed8", "$type": "color" },
        "800": { "$value": "#1e40af", "$type": "color" },
        "900": { "$value": "#1e3a8a", "$type": "color" },
        "950": { "$value": "#172554", "$type": "color" }
      }
    },
    "spacing": {
      "0":    { "$value": "0px",      "$type": "dimension" },
      "0-5":  { "$value": "2px",      "$type": "dimension" },
      "1":    { "$value": "4px",      "$type": "dimension" },
      "1-5":  { "$value": "6px",      "$type": "dimension" },
      "2":    { "$value": "8px",      "$type": "dimension" },
      "2-5":  { "$value": "10px",     "$type": "dimension" },
      "3":    { "$value": "12px",     "$type": "dimension" },
      "3-5":  { "$value": "14px",     "$type": "dimension" },
      "4":    { "$value": "16px",     "$type": "dimension" },
      "5":    { "$value": "20px",     "$type": "dimension" },
      "6":    { "$value": "24px",     "$type": "dimension" },
      "7":    { "$value": "28px",     "$type": "dimension" },
      "8":    { "$value": "32px",     "$type": "dimension" },
      "9":    { "$value": "36px",     "$type": "dimension" },
      "10":   { "$value": "40px",     "$type": "dimension" },
      "11":   { "$value": "44px",     "$type": "dimension" },
      "12":   { "$value": "48px",     "$type": "dimension" },
      "14":   { "$value": "56px",     "$type": "dimension" },
      "16":   { "$value": "64px",     "$type": "dimension" },
      "20":   { "$value": "80px",     "$type": "dimension" },
      "24":   { "$value": "96px",     "$type": "dimension" },
      "28":   { "$value": "112px",    "$type": "dimension" },
      "32":   { "$value": "128px",    "$type": "dimension" },
      "36":   { "$value": "144px",    "$type": "dimension" },
      "40":   { "$value": "160px",    "$type": "dimension" },
      "48":   { "$value": "192px",    "$type": "dimension" },
      "56":   { "$value": "224px",    "$type": "dimension" },
      "64":   { "$value": "256px",    "$type": "dimension" },
      "80":   { "$value": "320px",    "$type": "dimension" },
      "96":   { "$value": "384px",    "$type": "dimension" }
    },
    "typography": {
      "fontFamily": {
        "sans":  { "$value": "ui-sans-serif, system-ui, -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, 'Helvetica Neue', Arial, sans-serif", "$type": "fontFamily" },
        "serif": { "$value": "ui-serif, Georgia, Cambria, 'Times New Roman', Times, serif", "$type": "fontFamily" },
        "mono":  { "$value": "ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, 'Liberation Mono', 'Courier New', monospace", "$type": "fontFamily" }
      },
      "fontSize": {
        "xs":   { "$value": "12px", "$type": "dimension" },
        "sm":   { "$value": "14px", "$type": "dimension" },
        "base": { "$value": "16px", "$type": "dimension" },
        "lg":   { "$value": "18px", "$type": "dimension" },
        "xl":   { "$value": "20px", "$type": "dimension" },
        "2xl":  { "$value": "24px", "$type": "dimension" },
        "3xl":  { "$value": "30px", "$type": "dimension" },
        "4xl":  { "$value": "36px", "$type": "dimension" },
        "5xl":  { "$value": "48px", "$type": "dimension" },
        "6xl":  { "$value": "60px", "$type": "dimension" },
        "7xl":  { "$value": "72px", "$type": "dimension" }
      },
      "fontWeight": {
        "thin":       { "$value": 100, "$type": "fontWeight" },
        "extralight": { "$value": 200, "$type": "fontWeight" },
        "light":      { "$value": 300, "$type": "fontWeight" },
        "normal":     { "$value": 400, "$type": "fontWeight" },
        "medium":     { "$value": 500, "$type": "fontWeight" },
        "semibold":   { "$value": 600, "$type": "fontWeight" },
        "bold":       { "$value": 700, "$type": "fontWeight" },
        "extrabold":  { "$value": 800, "$type": "fontWeight" },
        "black":      { "$value": 900, "$type": "fontWeight" }
      },
      "lineHeight": {
        "none":    { "$value": 1,    "$type": "number" },
        "tight":   { "$value": 1.25, "$type": "number" },
        "snug":    { "$value": 1.375,"$type": "number" },
        "normal":  { "$value": 1.5,  "$type": "number" },
        "relaxed": { "$value": 1.625,"$type": "number" },
        "loose":   { "$value": 2,    "$type": "number" }
      },
      "letterSpacing": {
        "tighter": { "$value": "-0.05em", "$type": "dimension" },
        "tight":   { "$value": "-0.025em","$type": "dimension" },
        "normal":  { "$value": "0em",     "$type": "dimension" },
        "wide":    { "$value": "0.025em", "$type": "dimension" },
        "wider":   { "$value": "0.05em",  "$type": "dimension" },
        "widest":  { "$value": "0.1em",   "$type": "dimension" }
      }
    },
    "borderRadius": {
      "none":    { "$value": "0px",     "$type": "dimension" },
      "sm":      { "$value": "2px",     "$type": "dimension" },
      "default": { "$value": "4px",     "$type": "dimension" },
      "md":      { "$value": "6px",     "$type": "dimension" },
      "lg":      { "$value": "8px",     "$type": "dimension" },
      "xl":      { "$value": "12px",    "$type": "dimension" },
      "2xl":     { "$value": "16px",    "$type": "dimension" },
      "3xl":     { "$value": "24px",    "$type": "dimension" },
      "full":    { "$value": "9999px",  "$type": "dimension" }
    },
    "shadow": {
      "none":    { "$value": "none", "$type": "shadow" },
      "sm":      { "$value": "0 1px 2px 0 rgba(0,0,0,0.05)", "$type": "shadow" },
      "default": { "$value": "0 1px 3px 0 rgba(0,0,0,0.1), 0 1px 2px -1px rgba(0,0,0,0.1)", "$type": "shadow" },
      "md":      { "$value": "0 4px 6px -1px rgba(0,0,0,0.1), 0 2px 4px -2px rgba(0,0,0,0.1)", "$type": "shadow" },
      "lg":      { "$value": "0 10px 15px -3px rgba(0,0,0,0.1), 0 4px 6px -4px rgba(0,0,0,0.1)", "$type": "shadow" },
      "xl":      { "$value": "0 20px 25px -5px rgba(0,0,0,0.1), 0 8px 10px -6px rgba(0,0,0,0.1)", "$type": "shadow" },
      "2xl":     { "$value": "0 25px 50px -12px rgba(0,0,0,0.25)", "$type": "shadow" },
      "inner":   { "$value": "inset 0 2px 4px 0 rgba(0,0,0,0.05)", "$type": "shadow" }
    },
    "opacity": {
      "0":   { "$value": 0,    "$type": "number" },
      "5":   { "$value": 0.05, "$type": "number" },
      "10":  { "$value": 0.1,  "$type": "number" },
      "20":  { "$value": 0.2,  "$type": "number" },
      "25":  { "$value": 0.25, "$type": "number" },
      "50":  { "$value": 0.5,  "$type": "number" },
      "75":  { "$value": 0.75, "$type": "number" },
      "90":  { "$value": 0.9,  "$type": "number" },
      "100": { "$value": 1,    "$type": "number" }
    }
  },

  "semantic": {
    "color": {
      "background": {
        "default": { "$value": "{primitive.color.white}",       "$type": "color", "$description": "Page/app background" },
        "subtle":   { "$value": "{primitive.color.neutral.50}", "$type": "color", "$description": "Subtle section background" },
        "muted":    { "$value": "{primitive.color.neutral.100}","$type": "color", "$description": "Muted / secondary background" },
        "inverse":  { "$value": "{primitive.color.neutral.900}","$type": "color", "$description": "Dark / inverse background" },
        "brand":    { "$value": "{primitive.color.brand.50}",   "$type": "color", "$description": "Brand-tinted background" }
      },
      "text": {
        "default":  { "$value": "{primitive.color.neutral.900}","$type": "color", "$description": "Primary body text" },
        "subtle":   { "$value": "{primitive.color.neutral.700}","$type": "color", "$description": "Secondary / supporting text" },
        "muted":    { "$value": "{primitive.color.neutral.500}","$type": "color", "$description": "Placeholder, metadata" },
        "disabled": { "$value": "{primitive.color.neutral.300}","$type": "color", "$description": "Disabled state text" },
        "inverse":  { "$value": "{primitive.color.white}",      "$type": "color", "$description": "Text on dark backgrounds" },
        "brand":    { "$value": "{primitive.color.brand.600}",  "$type": "color", "$description": "Brand-colored text / links" },
        "error":    { "$value": "{primitive.color.red.600}",    "$type": "color", "$description": "Error message text" },
        "warning":  { "$value": "{primitive.color.yellow.700}", "$type": "color", "$description": "Warning message text" },
        "success":  { "$value": "{primitive.color.green.600}",  "$type": "color", "$description": "Success message text" },
        "info":     { "$value": "{primitive.color.blue.600}",   "$type": "color", "$description": "Info message text" }
      },
      "border": {
        "default": { "$value": "{primitive.color.neutral.200}", "$type": "color", "$description": "Default border" },
        "subtle":  { "$value": "{primitive.color.neutral.100}", "$type": "color", "$description": "Subtle / low-emphasis border" },
        "strong":  { "$value": "{primitive.color.neutral.300}", "$type": "color", "$description": "Strong / high-emphasis border" },
        "focus":   { "$value": "{primitive.color.brand.500}",   "$type": "color", "$description": "Keyboard focus ring" },
        "error":   { "$value": "{primitive.color.red.400}",     "$type": "color", "$description": "Error state border" }
      },
      "interactive": {
        "primary": {
          "bg":          { "$value": "{primitive.color.brand.600}", "$type": "color" },
          "bgHover":     { "$value": "{primitive.color.brand.700}", "$type": "color" },
          "bgActive":    { "$value": "{primitive.color.brand.800}", "$type": "color" },
          "bgDisabled":  { "$value": "{primitive.color.neutral.200}","$type": "color" },
          "text":        { "$value": "{primitive.color.white}",      "$type": "color" },
          "textDisabled":{ "$value": "{primitive.color.neutral.400}","$type": "color" }
        },
        "secondary": {
          "bg":       { "$value": "{primitive.color.white}",       "$type": "color" },
          "bgHover":  { "$value": "{primitive.color.neutral.50}",  "$type": "color" },
          "bgActive": { "$value": "{primitive.color.neutral.100}", "$type": "color" },
          "text":     { "$value": "{primitive.color.neutral.900}", "$type": "color" },
          "border":   { "$value": "{primitive.color.neutral.300}", "$type": "color" }
        },
        "ghost": {
          "bg":       { "$value": "transparent",                   "$type": "color" },
          "bgHover":  { "$value": "{primitive.color.neutral.100}", "$type": "color" },
          "bgActive": { "$value": "{primitive.color.neutral.200}", "$type": "color" },
          "text":     { "$value": "{primitive.color.neutral.700}", "$type": "color" }
        },
        "destructive": {
          "bg":       { "$value": "{primitive.color.red.600}", "$type": "color" },
          "bgHover":  { "$value": "{primitive.color.red.700}", "$type": "color" },
          "bgActive": { "$value": "{primitive.color.red.800}", "$type": "color" },
          "text":     { "$value": "{primitive.color.white}",   "$type": "color" }
        }
      },
      "status": {
        "error":   {
          "bg":     { "$value": "{primitive.color.red.50}",     "$type": "color" },
          "text":   { "$value": "{primitive.color.red.700}",    "$type": "color" },
          "border": { "$value": "{primitive.color.red.200}",    "$type": "color" },
          "icon":   { "$value": "{primitive.color.red.500}",    "$type": "color" }
        },
        "warning": {
          "bg":     { "$value": "{primitive.color.yellow.50}",  "$type": "color" },
          "text":   { "$value": "{primitive.color.yellow.700}", "$type": "color" },
          "border": { "$value": "{primitive.color.yellow.200}", "$type": "color" },
          "icon":   { "$value": "{primitive.color.yellow.500}", "$type": "color" }
        },
        "success": {
          "bg":     { "$value": "{primitive.color.green.50}",   "$type": "color" },
          "text":   { "$value": "{primitive.color.green.700}",  "$type": "color" },
          "border": { "$value": "{primitive.color.green.200}",  "$type": "color" },
          "icon":   { "$value": "{primitive.color.green.500}",  "$type": "color" }
        },
        "info": {
          "bg":     { "$value": "{primitive.color.blue.50}",    "$type": "color" },
          "text":   { "$value": "{primitive.color.blue.700}",   "$type": "color" },
          "border": { "$value": "{primitive.color.blue.200}",   "$type": "color" },
          "icon":   { "$value": "{primitive.color.blue.500}",   "$type": "color" }
        }
      }
    },
    "spacing": {
      "component": {
        "xs":  { "$value": "{primitive.spacing.1}",  "$type": "dimension", "$description": "4px — tight internal padding" },
        "sm":  { "$value": "{primitive.spacing.2}",  "$type": "dimension", "$description": "8px — small component padding" },
        "md":  { "$value": "{primitive.spacing.4}",  "$type": "dimension", "$description": "16px — default component padding" },
        "lg":  { "$value": "{primitive.spacing.6}",  "$type": "dimension", "$description": "24px — large component padding" },
        "xl":  { "$value": "{primitive.spacing.8}",  "$type": "dimension", "$description": "32px — extra-large padding" }
      },
      "layout": {
        "xs":  { "$value": "{primitive.spacing.4}",  "$type": "dimension", "$description": "16px — tight layout gap" },
        "sm":  { "$value": "{primitive.spacing.6}",  "$type": "dimension", "$description": "24px" },
        "md":  { "$value": "{primitive.spacing.8}",  "$type": "dimension", "$description": "32px — default section gap" },
        "lg":  { "$value": "{primitive.spacing.12}", "$type": "dimension", "$description": "48px" },
        "xl":  { "$value": "{primitive.spacing.16}", "$type": "dimension", "$description": "64px" },
        "2xl": { "$value": "{primitive.spacing.24}", "$type": "dimension", "$description": "96px — page-level spacing" }
      }
    },
    "typography": {
      "body": {
        "sm":   { "$value": "{primitive.typography.fontSize.sm}",   "$type": "dimension" },
        "base": { "$value": "{primitive.typography.fontSize.base}", "$type": "dimension" },
        "lg":   { "$value": "{primitive.typography.fontSize.lg}",   "$type": "dimension" }
      },
      "heading": {
        "xs":  { "$value": "{primitive.typography.fontSize.lg}",  "$type": "dimension" },
        "sm":  { "$value": "{primitive.typography.fontSize.xl}",  "$type": "dimension" },
        "md":  { "$value": "{primitive.typography.fontSize.2xl}", "$type": "dimension" },
        "lg":  { "$value": "{primitive.typography.fontSize.3xl}", "$type": "dimension" },
        "xl":  { "$value": "{primitive.typography.fontSize.4xl}", "$type": "dimension" },
        "2xl": { "$value": "{primitive.typography.fontSize.5xl}", "$type": "dimension" }
      },
      "label": {
        "xs":   { "$value": "{primitive.typography.fontSize.xs}",  "$type": "dimension" },
        "sm":   { "$value": "{primitive.typography.fontSize.sm}",  "$type": "dimension" },
        "base": { "$value": "{primitive.typography.fontSize.base}","$type": "dimension" }
      }
    }
  },

  "component": {
    "button": {
      "height": {
        "sm": { "$value": "{primitive.spacing.8}",  "$type": "dimension" },
        "md": { "$value": "{primitive.spacing.10}", "$type": "dimension" },
        "lg": { "$value": "{primitive.spacing.12}", "$type": "dimension" }
      },
      "paddingX": {
        "sm": { "$value": "{primitive.spacing.3}", "$type": "dimension" },
        "md": { "$value": "{primitive.spacing.4}", "$type": "dimension" },
        "lg": { "$value": "{primitive.spacing.6}", "$type": "dimension" }
      },
      "fontSize": {
        "sm": { "$value": "{primitive.typography.fontSize.xs}",  "$type": "dimension" },
        "md": { "$value": "{primitive.typography.fontSize.sm}",  "$type": "dimension" },
        "lg": { "$value": "{primitive.typography.fontSize.base}","$type": "dimension" }
      },
      "fontWeight": { "$value": "{primitive.typography.fontWeight.medium}", "$type": "fontWeight" },
      "radius":     { "$value": "{primitive.borderRadius.md}",              "$type": "dimension" },
      "gap":        { "$value": "{primitive.spacing.2}",                    "$type": "dimension" }
    },
    "input": {
      "height": {
        "sm": { "$value": "{primitive.spacing.8}",  "$type": "dimension" },
        "md": { "$value": "{primitive.spacing.10}", "$type": "dimension" },
        "lg": { "$value": "{primitive.spacing.12}", "$type": "dimension" }
      },
      "paddingX":      { "$value": "{primitive.spacing.3}",                      "$type": "dimension" },
      "fontSize":      { "$value": "{primitive.typography.fontSize.sm}",          "$type": "dimension" },
      "radius":        { "$value": "{primitive.borderRadius.md}",                 "$type": "dimension" },
      "bg":            { "$value": "{primitive.color.white}",                     "$type": "color" },
      "bgDisabled":    { "$value": "{primitive.color.neutral.50}",                "$type": "color" },
      "border":        { "$value": "{semantic.color.border.default}",             "$type": "color" },
      "borderFocus":   { "$value": "{semantic.color.border.focus}",               "$type": "color" },
      "borderError":   { "$value": "{semantic.color.border.error}",               "$type": "color" },
      "text":          { "$value": "{semantic.color.text.default}",               "$type": "color" },
      "placeholder":   { "$value": "{semantic.color.text.muted}",                 "$type": "color" }
    },
    "card": {
      "padding": {
        "sm": { "$value": "{primitive.spacing.4}", "$type": "dimension" },
        "md": { "$value": "{primitive.spacing.6}", "$type": "dimension" },
        "lg": { "$value": "{primitive.spacing.8}", "$type": "dimension" }
      },
      "radius":  { "$value": "{primitive.borderRadius.lg}",          "$type": "dimension" },
      "border":  { "$value": "{semantic.color.border.subtle}",       "$type": "color" },
      "shadow":  { "$value": "{primitive.shadow.sm}",                "$type": "shadow" },
      "bg":      { "$value": "{primitive.color.white}",              "$type": "color" }
    },
    "badge": {
      "paddingX":   { "$value": "{primitive.spacing.2}",                    "$type": "dimension" },
      "paddingY":   { "$value": "{primitive.spacing.0-5}",                  "$type": "dimension" },
      "fontSize":   { "$value": "{primitive.typography.fontSize.xs}",       "$type": "dimension" },
      "fontWeight": { "$value": "{primitive.typography.fontWeight.medium}",  "$type": "fontWeight" },
      "radius":     { "$value": "{primitive.borderRadius.full}",             "$type": "dimension" }
    },
    "tooltip": {
      "padding":   { "$value": "{primitive.spacing.2}",                     "$type": "dimension" },
      "fontSize":  { "$value": "{primitive.typography.fontSize.xs}",        "$type": "dimension" },
      "radius":    { "$value": "{primitive.borderRadius.md}",               "$type": "dimension" },
      "bg":        { "$value": "{primitive.color.neutral.900}",             "$type": "color" },
      "text":      { "$value": "{primitive.color.white}",                   "$type": "color" }
    },
    "modal": {
      "padding":      { "$value": "{primitive.spacing.6}",            "$type": "dimension" },
      "radius":       { "$value": "{primitive.borderRadius.xl}",      "$type": "dimension" },
      "shadow":       { "$value": "{primitive.shadow.xl}",            "$type": "shadow" },
      "bg":           { "$value": "{primitive.color.white}",          "$type": "color" },
      "overlayBg":    { "$value": "rgba(0,0,0,0.5)",                  "$type": "color" },
      "maxWidth": {
        "sm":   { "$value": "{primitive.spacing.80}",  "$type": "dimension" },
        "md":   { "$value": "{primitive.spacing.96}",  "$type": "dimension" }
      }
    }
  }
}
