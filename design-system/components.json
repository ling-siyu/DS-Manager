{
  "$schema": "https://design-system-manager/schemas/components.json",
  "$version": "0.1.0",
  "$description": "Registry of all design system components. AI agents must check here before creating new components.",
  "components": [
    {
      "name": "Button",
      "path": "src/components/ui/Button.tsx",
      "description": "Primary interactive element. Variants, sizes, and disabled state — styled entirely from DSM tokens.",
      "variants": ["primary", "secondary", "ghost", "destructive"],
      "sizes": ["sm", "md", "lg"],
      "props": {
        "variant":  { "type": "string", "default": "primary", "options": ["primary", "secondary", "ghost", "destructive"] },
        "size":     { "type": "string", "default": "md",      "options": ["sm", "md", "lg"] },
        "fullWidth":{ "type": "boolean","default": false },
        "disabled": { "type": "boolean","default": false },
        "children": { "type": "ReactNode", "required": true }
      },
      "previewProps": { "children": "Button" },
      "previewScenarios": [
        { "name": "Primary",     "props": { "variant": "primary",     "children": "Primary" } },
        { "name": "Secondary",   "props": { "variant": "secondary",   "children": "Secondary" } },
        { "name": "Ghost",       "props": { "variant": "ghost",       "children": "Ghost" } },
        { "name": "Destructive", "props": { "variant": "destructive", "children": "Delete" } },
        { "name": "Disabled",    "props": { "disabled": true,          "children": "Disabled" } },
        { "name": "Large",       "props": { "size": "lg",              "children": "Large button" } }
      ],
      "tokens": ["component.button.*", "semantic.color.interactive.*"],
      "status": "stable",
      "doNotCreate": true
    },
    {
      "name": "Card",
      "path": "src/components/ui/Card.tsx",
      "description": "Surface container with consistent padding, radius, and shadow from DSM tokens.",
      "variants": ["default", "flat", "elevated"],
      "sizes": ["sm", "md", "lg"],
      "props": {
        "variant": { "type": "string", "default": "default", "options": ["default", "flat", "elevated"] },
        "padding": { "type": "string", "default": "md",      "options": ["sm", "md", "lg"] },
        "children":{ "type": "ReactNode", "required": true }
      },
      "previewProps": { "children": "Card content" },
      "previewScenarios": [
        { "name": "Default",  "props": { "variant": "default",  "children": "Default card" } },
        { "name": "Elevated", "props": { "variant": "elevated", "children": "Elevated card" } },
        { "name": "Flat",     "props": { "variant": "flat",     "children": "Flat card" } }
      ],
      "tokens": ["component.card.*"],
      "status": "stable",
      "doNotCreate": true
    },
    {
      "name": "Badge",
      "path": "src/components/ui/Badge.tsx",
      "description": "Compact status or label indicator driven by DSM semantic text tokens.",
      "variants": ["neutral", "brand", "success", "warning", "error"],
      "props": {
        "variant": { "type": "string", "default": "neutral", "options": ["neutral", "brand", "success", "warning", "error"] },
        "children":{ "type": "ReactNode", "required": true }
      },
      "previewProps": { "children": "Badge" },
      "previewScenarios": [
        { "name": "Neutral", "props": { "variant": "neutral", "children": "Neutral" } },
        { "name": "Brand",   "props": { "variant": "brand",   "children": "Brand" } },
        { "name": "Success", "props": { "variant": "success", "children": "Success" } },
        { "name": "Warning", "props": { "variant": "warning", "children": "Warning" } },
        { "name": "Error",   "props": { "variant": "error",   "children": "Error" } }
      ],
      "tokens": ["semantic.color.text.*", "semantic.color.background.subtle"],
      "status": "stable",
      "doNotCreate": true
    }
  ],
  "conventions": {
    "naming": "PascalCase for component names, camelCase for props",
    "location": "All UI primitives live in src/components/ui/. Feature components in src/components/features/.",
    "newComponent": "Run `dsm generate-context` after adding a new component to update CLAUDE.md"
  }
}
